# Frontend API URL used by the client to call the local backend
VITE_API_URL=http://localhost:8787

# Supabase realtime connection
VITE_SUPABASE_URL=https://your-supabase-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Cloudflare CLI auth for worker deploy
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token

# Optional shared sketch id used by the backend/R2 storage
SKETCH_DOCUMENT_ID=shared

# Note: R2 bucket binding is configured in backend/wrangler.toml as SKETCHES_BUCKET.
# The backend reads/writes shared.png and shared.json to that R2 bucket.
